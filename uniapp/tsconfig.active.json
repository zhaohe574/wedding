{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "allowJs": true,
        "skipLibCheck": true,
        "types": ["@dcloudio/types", "vite/client"],
        "paths": {
            "@/*": ["./src/*"],
            "@tuniao/tnui-vue3-uniapp": ["./typings/shims/tnui-package-stub"],
            "@tuniao/tnui-vue3-uniapp/components/*": ["./typings/shims/tnui-component-stub"],
            "tnuiv3p-tn-comment-list": ["./typings/shims/tn-comment-list-stub"],
            "tnuiv3p-tn-comment-list/*": ["./typings/shims/tn-comment-list-stub"]
        }
    },
    "include": [
        "src/App.vue",
        "src/main.ts",
        "src/api/**/*.ts",
        "src/components/**/*.vue",
        "src/components/**/*.ts",
        "src/config/**/*.ts",
        "src/hooks/**/*.ts",
        "src/mixins/**/*.ts",
        "src/pages/dynamic/**/*.vue",
        "src/pages/dynamic_detail/**/*.vue",
        "src/pages/dynamic_publish/**/*.vue",
        "src/pages/index/**/*.vue",
        "src/pages/login/**/*.vue",
        "src/pages/news/**/*.vue",
        "src/pages/news_detail/**/*.vue",
        "src/pages/notification/**/*.vue",
        "src/pages/review/**/*.vue",
        "src/pages/search/**/*.vue",
        "src/pages/user/**/*.vue",
        "src/packages/pages/cart/**/*.vue",
        "src/packages/pages/cart_plan/**/*.vue",
        "src/packages/pages/order_confirm/**/*.vue",
        "src/packages/pages/share_plan/**/*.vue",
        "src/packages/pages/staff_detail/**/*.vue",
        "src/packages/pages/staff_favorite/**/*.vue",
        "src/pages/staff_list/**/*.vue",
        "src/packages/pages/staff_package_list/**/*.vue",
        "src/packages/pages/staff_schedule/**/*.vue",
        "src/packages/pages/staff_work_detail/**/*.vue",
        "src/plugins/**/*.ts",
        "src/router/**/*.ts",
        "src/stores/**/*.ts",
        "src/styles/**/*.ts",
        "src/utils/**/*.ts",
        "src/utils/**/*.d.ts",
        "typings/**/*.d.ts"
    ],
    "exclude": [
        "src/api/aftersale.ts",
        "src/api/pay.ts",
        "src/pages/aftersale/**/*",
        "src/pages/order/**/*",
        "src/pages/order_detail/**/*",
        "src/pages/payment_result/**/*",
        "src/components/payment/**/*",
        "src/api/recharge.ts",
        "src/utils/pay/**/*",
        "src/packages/pages/recharge/**/*",
        "src/packages/pages/recharge_record/**/*",
        "src/packages/pages/staff_center/**/*",
        "src/packages/pages/staff_dynamic_edit/**/*",
        "src/packages/pages/staff_dynamic_list/**/*",
        "src/packages/pages/staff_order_detail/**/*",
        "src/packages/pages/staff_order_list/**/*",
        "src/packages/pages/staff_package_edit/**/*",
        "src/packages/pages/staff_profile/**/*",
        "src/packages/pages/staff_work_edit/**/*",
        "src/packages/pages/staff_work_list/**/*",
        "src/packages/pages/user_wallet/**/*"
    ]
}
