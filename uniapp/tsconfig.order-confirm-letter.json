{
    "extends": "./tsconfig.active.json",
    "include": [
        "src/App.vue",
        "src/main.ts",
        "src/api/**/*.ts",
        "src/components/**/*.vue",
        "src/components/**/*.ts",
        "src/config/**/*.ts",
        "src/hooks/**/*.ts",
        "src/mixins/**/*.ts",
        "src/pages/order_detail/**/*.vue",
        "src/packages/pages/order_confirm/**/*.vue",
        "src/packages/pages/staff_order_detail/**/*.vue",
        "src/plugins/**/*.ts",
        "src/router/**/*.ts",
        "src/stores/**/*.ts",
